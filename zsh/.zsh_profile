
alias ls='ls --color=auto'
alias la='ls -lah'
alias ll='ls -lh'
alias ..='cd ..'

alias xbox="upower -e | grep gaming_input | xargs upower -i"
alias copy="xclip -selection | clipboard"

alias o="open ."
alias zshrr="source ~/.zshrc"
alias sshcopy="pbcopy < ~/.ssh/id_rsa.pub"
alias kill4000="lsof -ti:4000 | xargs kill"

alias k="kubectl"

alias v="nvim"
alias vimc="cd ~/dotfiles/nvim && nvim ."
alias obsi="cd $HOME/Documents/Obsidian\ Vault && nvim ."

alias pew="git log --format='%h - %an, %ar — %s'" # dev...master

alias g="git"
alias gsd="git switch dev"
alias gl="git pull"
alias gp="git push"
alias gc="git commit -m"
alias gs="git switch"
alias gmd="git switch dev && git pull && git switch - && git merge dev"
alias nah="git reset --hard && git clean -df"
alias glo="git log --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit"
alias gclear="gb | grep -v 'develop' | grep -v 'dev' | grep -v 'master' | grep -v 'main' | grep -v 'release' | xargs git branch -d"

